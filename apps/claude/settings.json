{
  "cleanupPeriodDays": 9999,
  "env": {
    "CLAUDE_CODE_MONITOR_GHOSTTY_ASKED": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_DISABLE_FAST_MODE": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "20"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "ExitPlanMode",
      "Skill",
      "Read(/**)",
      "Read(///tmp/**)",
      "Read(~/.claude/**)",
      "Edit(/**)",
      "Write(/**)",
      "Write(///tmp/**)",
      "Bash([ *)",
      "Bash(\\rm /tmp/aidlc-*)",
      "Bash(bash -n *)",
      "Bash(bash /Users/keisuke/.claude/plugins/cache/ikeisuke-skills/tools/*/skills/session-title/bin/session-title.sh *)",
      "Bash(cat:*)",
      "Bash(cat > /tmp/*)",
      "Bash(codex *)",
      "Bash(command -v:*)",
      "Bash(curl -s --max-time 5 https://raw.githubusercontent.com/ikeisuke/ai-dlc-starter-kit/main/version.txt 2>/dev/null)",
      "Bash(curl * https://raw.githubusercontent.com/ikeisuke/ai-dlc-starter-kit/*)",
      "Bash(date *)",
      "Bash(diff *)",
      "Bash(dig *)",
      "Bash(docs/aidlc/bin/*)",
      "Bash(docs/aidlc/skills/*/bin/*)",
      "Bash(file *)",
      "Bash(find:*)",
      "Bash(gh auth status)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh run watch *)",
      "Bash(gh run download *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(ghq *)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout -b:*)",
      "Bash(git commit:*)",
      "Bash(git commit -m:*)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git merge-base *)",
      "Bash(git remote)",
      "Bash(git remote -v)",
      "Bash(git remote show:*)",
      "Bash(git reset --soft:*)",
      "Bash(git rev-parse *)",
      "Bash(git show:*)",
      "Bash(git status *)",
      "Bash(git switch:*)",
      "Bash(git push *)",
      "Bash(git tag *)",
      "Bash(git worktree list)",
      "Bash(grep:*)",
      "Bash(head *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(mktemp *)",
      "Bash(npm view *)",
      "Bash(npx markdownlint-cli2:*)",
      "Bash(open *)",
      "Bash(printf *)",
      "Bash(pwd *)",
      "Bash(python3 /Users/keisuke/.claude/plugins/cache/ikeisuke-skills/tools/*/skills/suggest-permissions/*)",
      "Bash(sleep *)",
      "Bash(rg *)",
      "Bash(tail *)",
      "Bash(tee -a docs/cycles/*/history/*)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(git fetch *)",
      "Bash(GIT_TERMINAL_PROMPT=0 git fetch:*)",
      "Bash(git mv *)",
      "Bash(gh label *)",
      "Bash(gh pr view *)",
      "Bash(gh repo view *)",
      "Bash(git commit -F:*)",
      "Bash(touch *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Bash(*~/.aws/*)",
      "Bash(*~/.ssh/*)",
      "Bash(*~/.config/gh/*)",
      "Bash(*aws sso get-role-credentials*)",
      "Bash(*aws configure list-profiles*)",
      "Bash(*aws configure export-credentials*)",
      "Bash(*security find-generic-password*)",
      "Bash(*security dump-keychain*)"
    ],
    "ask": [
      "Bash(git push*--force *)",
      "Bash(git push*--force-with-lease *)",
      "Bash(git branch*-D *)",
      "Bash(git branch*--force *)",
      "Bash(git tag*-d *)",
      "Bash(git checkout -- *)",
      "Bash(git checkout . *)",
      "Bash(gh pr merge *)",
      "Bash(find *-exec *)",
      "Bash(find *-execdir *)"
    ],
    "defaultMode": "auto"
  },
  "sandbox": {
    "enabled": false
  },
  "enabledMcpjsonServers": [],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/plugins/marketplaces/ikeisuke-skills/skills/session-title/bin/session-title.sh \"$(basename \"$(git rev-parse --show-toplevel 2>/dev/null)\" 2>/dev/null)\" \"$(git branch --show-current 2>/dev/null)\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": false,
    "document-skills@anthropic-agent-skills": false,
    "example-skills@anthropic-agent-skills": true,
    "tools@ikeisuke-skills": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ikeisuke-skills": {
      "source": {
        "source": "github",
        "repo": "ikeisuke/claude-skills"
      },
      "autoUpdate": true
    }
  },
  "voiceEnabled": true,
  "autoMemoryEnabled": false,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.py"
  }
}
