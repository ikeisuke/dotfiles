#!/usr/bin/env bash
# scripts/doctor — dotfiles environment health check
#
# Read-only checks for environment drift (symlinks, Brewfile, tool versions,
# platform-specific state). Pair with `./setup.sh` to apply fixes.
#
# Run from repo root: `./scripts/doctor` (not on PATH; this is a maintenance script).
#
# Exit codes:
#   0  All checks passed (warnings allowed)
#   1  Fixable inconsistency detected
#   2  Script internal error

set -euo pipefail

DIR="$(cd "$(dirname "$0")/.." && pwd)"

# ── Color ────────────────────────────────────────────────
if [ -t 1 ] && command -v tput >/dev/null 2>&1 && [ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]; then
  C_OK=$(tput setaf 2)
  C_NG=$(tput setaf 1)
  C_WARN=$(tput setaf 3)
  C_DIM=$(tput setaf 8 2>/dev/null || tput setaf 7)
  C_BOLD=$(tput bold)
  C_RESET=$(tput sgr0)
else
  C_OK="" C_NG="" C_WARN="" C_DIM="" C_BOLD="" C_RESET=""
fi

RC=0

# ── Platform detection ───────────────────────────────────
MACOSX=0 LINUX=0 WSL2=0
case "${OSTYPE:-}" in
  darwin*) MACOSX=1 ;;
  linux*)  LINUX=1 ;;
esac
if [ "$LINUX" = 1 ] && { uname -r 2>/dev/null | grep -qi WSL2 || grep -qi WSL2 /proc/version 2>/dev/null; }; then
  WSL2=1
fi

# ── Output helpers ───────────────────────────────────────
section() { printf '%s== %s ==%s\n' "$C_BOLD" "$1" "$C_RESET"; }
ok()      { printf '  %s✓%s %s\n' "$C_OK" "$C_RESET" "$1"; }
warn()    { printf '  %s⚠%s %s\n' "$C_WARN" "$C_RESET" "$1"; }
ng()      { printf '  %s✗%s %s\n' "$C_NG" "$C_RESET" "$1"; RC=1; }
info()    { printf '  %s-%s %s\n' "$C_DIM" "$C_RESET" "$1"; }

shorten() {
  local p="$1"
  case "$p" in
    "$DIR"/*)  printf '<dotfiles>%s' "${p#"$DIR"}" ;;
    "$HOME"/*) printf '~%s' "${p#"$HOME"}" ;;
    *)         printf '%s' "$p" ;;
  esac
}

# Verify $1 is a symlink pointing to $2
check_link() {
  local link="$1" expected="$2"
  local short_link short_expected
  short_link=$(shorten "$link")
  short_expected=$(shorten "$expected")
  if [ ! -L "$link" ] && [ ! -e "$link" ]; then
    ng "$short_link: missing (expected: $short_expected)"
    return 0
  fi
  if [ ! -L "$link" ]; then
    ng "$short_link: not a symlink (expected: $short_expected)"
    return 0
  fi
  local actual short_actual
  actual=$(readlink "$link")
  if [ "$actual" = "$expected" ]; then
    ok "$short_link → $short_expected"
  else
    short_actual=$(shorten "$actual")
    ng "$short_link → $short_actual (expected: $short_expected)"
  fi
}

print_version() {
  local name="$1" cmd="$2" v
  if ! command -v "$name" >/dev/null 2>&1; then
    warn "$(printf '%-10s (not installed)' "$name")"
    return
  fi
  v=$(eval "$cmd" 2>&1 | head -n 1 || true)
  ok "$(printf '%-10s %s' "$name" "$v")"
}

# ── Brewfile ─────────────────────────────────────────────
section "Brewfile"
if ! command -v brew >/dev/null 2>&1; then
  warn "brew not found (install: https://brew.sh)"
elif [ ! -f "$DIR/Brewfile" ]; then
  warn "Brewfile missing"
elif brew bundle check --file="$DIR/Brewfile" >/dev/null 2>&1; then
  ok "brew bundle check: all packages installed"
else
  ng "brew bundle check: missing packages"
  brew bundle check --verbose --file="$DIR/Brewfile" 2>&1 | sed 's/^/    /' || true
fi

# ── Symlinks ─────────────────────────────────────────────
section "Symlinks"
check_link "$HOME/.gitconfig"               "$DIR/apps/git/gitconfig"
check_link "$HOME/.config/git/ignore"       "$DIR/apps/git/gitignore"
check_link "$HOME/.zshenv"                  "$DIR/zsh/zshenv"
check_link "$HOME/.zprofile"                "$DIR/zsh/zprofile"
check_link "$HOME/.zshrc"                   "$DIR/zsh/zshrc"
check_link "$HOME/.config/tmux/tmux.conf"   "$DIR/apps/tmux/tmux.conf"
check_link "$HOME/.claude/CLAUDE.md"        "$DIR/apps/claude/CLAUDE.md"
check_link "$HOME/.claude/settings.json"    "$DIR/apps/claude/settings.json"
check_link "$HOME/.claude/keybindings.json" "$DIR/apps/claude/keybindings.json"
check_link "$HOME/.claude/statusline.py"    "$DIR/apps/claude/statusline.py"
check_link "$HOME/.config/gh/config.yml"    "$DIR/apps/gh/config.yml"
check_link "$HOME/.config/zeno/config.yml"  "$DIR/apps/zeno/config.yml"
check_link "$HOME/.config/fzf/fzfrc"        "$DIR/apps/fzf/fzfrc"
check_link "$HOME/.vimrc"                   "$DIR/apps/vim/vimrc"
if [ -d "$DIR/apps/ghostty" ]; then
  check_link "$HOME/.config/ghostty/config" "$DIR/apps/ghostty/config"
fi
if [ -d "$DIR/bin" ]; then
  for f in "$DIR/bin/"*; do
    [ -e "$f" ] || continue
    check_link "$HOME/.local/bin/$(basename "$f")" "$f"
  done
fi

# ── Tool versions ────────────────────────────────────────
section "Tool Versions"
[ "$MACOSX" = 1 ] && print_version brew "brew --version"
print_version rustup     "rustup --version"
print_version rustc      "rustc --version"
print_version cargo      "cargo --version"
print_version deno       "deno --version"
print_version git        "git --version"
print_version jj         "jj --version"
print_version zsh        "zsh --version"
print_version tmux       "tmux -V"
print_version node       "node --version"
print_version npm        "npm --version"
print_version claude     "claude --version"
print_version jailrun    "jailrun --version"
print_version gh         "gh --version"
print_version ghq        "ghq --version"
print_version vim        "vim --version"
print_version shellcheck "shellcheck --version"

# ── Platform ─────────────────────────────────────────────
section "Platform"
if [ "$MACOSX" = 1 ]; then
  ok "macOS detected ($(uname -r))"
elif [ "$WSL2" = 1 ]; then
  ok "WSL2 detected ($(uname -r))"

  if [ -r /sys/module/apparmor/parameters/enabled ]; then
    case "$(cat /sys/module/apparmor/parameters/enabled)" in
      Y) ok "AppArmor kernel: enabled" ;;
      *) ng "AppArmor kernel: disabled (run 'wsl --shutdown' from Windows)" ;;
    esac
  else
    ng "AppArmor kernel module not loaded (run 'wsl --shutdown' from Windows)"
  fi

  apparmor_missing=""
  command -v apparmor_parser >/dev/null 2>&1 || apparmor_missing="$apparmor_missing apparmor"
  command -v aa-status     >/dev/null 2>&1 || apparmor_missing="$apparmor_missing apparmor-utils"
  if [ -n "$apparmor_missing" ]; then
    warn "AppArmor userspace tools missing:$apparmor_missing"
    info "→ sudo apt install$apparmor_missing"
  else
    ok "AppArmor userspace tools installed"
  fi
elif [ "$LINUX" = 1 ]; then
  ok "Linux detected ($(uname -r))"
  info "WSL2 checks skipped (not WSL2)"
else
  warn "Unknown platform: ${OSTYPE:-unknown}"
fi

# ── Summary ──────────────────────────────────────────────
echo
if [ "$RC" -eq 0 ]; then
  printf '%s%s✓ All checks passed%s\n' "$C_BOLD" "$C_OK" "$C_RESET"
else
  printf '%s%s✗ Issues detected — run ./setup.sh to fix%s\n' "$C_BOLD" "$C_NG" "$C_RESET"
fi
exit "$RC"
